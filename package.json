{
  "name": "slidev-editable-pptx",
  "version": "0.1.0",
  "private": false,
  "description": "editable PPTX に変換可能な Slidev を構築する仕組み: Diag* 図コンポーネント（Slidev addon）+ HTML 実測 → ネイティブ図形再構築の変換器 + 図ジオメトリ lint",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fuj1g0n/slidev-editable-pptx.git"
  },
  "keywords": [
    "slidev-addon"
  ],
  "bin": {
    "slidev-editable-pptx": "bin/slidev-editable-pptx.mjs",
    "pptx-qa": "bin/pptx-qa.sh",
    "lint-diagrams": "bin/lint-diagrams.mjs",
    "lint-figures": "bin/lint-figures.mjs",
    "lint-drawio-bounds": "bin/lint-drawio-bounds.mjs",
    "figure-normalize": "bin/figure-normalize.mjs",
    "fetch-icons": "bin/fetch-icons.mjs",
    "diagram-icons": "bin/diagram-icons.mjs",
    "diag-extract-drawio": "bin/diag-extract-drawio.mjs"
  },
  "exports": {
    "./components/*": "./components/*",
    "./lib/*": "./lib/*"
  },
  "files": [
    "bin/",
    "components/",
    "lib/",
    "vendor/",
    "README.md"
  ],
  "engines": {
    "node": ">=20",
    "slidev": ">=52"
  },
  "dependencies": {
    "@iconify-json/octicon": "^1.2.29",
    "fflate": "^0.8.3",
    "fonteditor-core": "^2.6.3",
    "jszip": "^3.10.1",
    "pptxgenjs": "^4.0.1",
    "puppeteer-core": "^25.3.0",
    "subset-font": "^2.5.0"
  },
  "scripts": {
    "dev:fixture": "slidev fixture-components.md",
    "fixture:pdf": "slidev export fixture-components.md --format pdf --output out/fixture-components.pdf --executable-path \"$CHROME_PATH\"",
    "fixture:pptx": "SLIDES_ENTRY=fixture-components.md OUT=out/fixture-components-editable.pptx EMBED_FONTS=[] node bin/slidev-editable-pptx.mjs"
  },
  "devDependencies": {
    "@slidev/cli": "^52.16.0",
    "@slidev/theme-default": "^0.25.0",
    "playwright-chromium": "^1.61.1"
  }
}
